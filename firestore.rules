rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      // Shared inventory — all authenticated users see the same data
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidSupplier(data) {
      // name, portal, contactEmail, websiteUrl, ownerId, createdAt
      return data.keys().hasAll(['name', 'portal', 'ownerId', 'createdAt']) 
        && data.keys().size() <= 6
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 100
        && data.portal in ['eBay', 'Website', 'Direct', 'Other']
        && data.ownerId is string
        && data.createdAt == request.time;
    }

    function isValidBatch(data) {
      // supplierId, date, supplierRef, itemCount, costTotal, status, ownerId, createdAt
      return data.keys().hasAll(['supplierId', 'date', 'status', 'ownerId', 'createdAt'])
        && data.keys().size() <= 8
        && isValidId(data.supplierId)
        && data.status in ['received', 'processing', 'completed']
        && data.ownerId is string
        && data.createdAt == request.time
        && exists(/databases/$(database)/documents/suppliers/$(data.supplierId));
    }

    function isValidDevice(data) {
      // imei, model, brand, batchId, supplierId, condition, purchasePrice, status, salePrice, saleDate, salePlatform, orderId, updatedAt, ownerId, createdAt
      return data.keys().hasAll(['imei', 'model', 'brand', 'batchId', 'supplierId', 'status', 'purchasePrice', 'ownerId', 'createdAt'])
        && data.keys().size() <= 15
        && data.imei is string && data.imei.size() >= 8 && data.imei.size() <= 32
        && data.model is string && data.model.size() <= 100
        && data.brand is string && data.brand.size() <= 50
        && isValidId(data.batchId)
        && isValidId(data.supplierId)
        && data.status in ['available', 'sold', 'returned', 'lost']
        && data.purchasePrice is number && data.purchasePrice >= 0
        && data.ownerId is string
        && data.createdAt == request.time
        && exists(/databases/$(database)/documents/batches/$(data.batchId));
    }

    function isValidOrder(data) {
      // platform, platformOrderId, totalAmount, date, status, deviceIds, customerName, ownerId, createdAt
      return data.keys().hasAll(['platform', 'platformOrderId', 'totalAmount', 'date', 'deviceIds', 'ownerId', 'createdAt'])
        && data.keys().size() <= 10
        && data.platform is string
        && data.totalAmount is number
        && data.deviceIds is list && data.deviceIds.size() > 0 && data.deviceIds.size() <= 50
        && data.ownerId is string
        && data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /suppliers/{supplierId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(supplierId) && isValidSupplier(incoming());
      allow update: if isSignedIn() && isValidSupplier(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'portal', 'contactEmail', 'websiteUrl']);
      allow delete: if isSignedIn();
    }

    match /batches/{batchId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(batchId) && isValidBatch(incoming());
      allow update: if isSignedIn() && isValidBatch(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'supplierRef', 'itemCount', 'costTotal']);
      allow delete: if isSignedIn();
    }

    match /devices/{deviceId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(deviceId) && isValidDevice(incoming());
      allow update: if isSignedIn() && isValidDevice(incoming())
        && (
          // Action: Mark Sold
          (incoming().status == 'sold' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'salePrice', 'saleDate', 'salePlatform', 'orderId'])) ||
          // Action: Update Info
          (incoming().diff(existing()).affectedKeys().hasOnly(['model', 'brand', 'condition', 'status', 'updatedAt']))
        );
      allow delete: if isSignedIn();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isSignedIn() && isValidOrder(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'customerName']);
      allow delete: if isSignedIn();
    }
  }
}
