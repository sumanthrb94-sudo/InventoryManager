rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Shared workspace — any authenticated user (Google Sign-In) can read and write.
    // Authorization (role-based access) will be layered on top later.

    match /inventoryUnits/{unitId} {
      allow read, write: if isSignedIn();
    }

    match /suppliers/{supplierId} {
      allow read, write: if isSignedIn();
    }

    match /batches/{batchId} {
      allow read, write: if isSignedIn();
    }

    match /inventoryEvents/{eventId} {
      allow read, write: if isSignedIn();
    }

    match /dailyUpdates/{updateId} {
      allow read, write: if isSignedIn();
    }

    match /activeListings/{listingId} {
      allow read, write: if isSignedIn();
    }

    match /sourceDocuments/{docId} {
      allow read, write: if isSignedIn();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}